  57          //延时函数
  58          void Delay_ms(unsigned int ms) {
  59   1          unsigned int i, j;
  60   1          for(i = ms; i > 0; i--)
  61   1              for(j = 110; j > 0; j--); 
  62   1      }
  63          
  64          //音乐初始化
  65          void Music_Init(void) {
  66   1          TMOD &= 0xF0; 
  67   1          TMOD |= 0x01; 
  68   1          EA = 1;       
  69   1          ET0 = 1;      
  70   1          BUZZER = 1;   // 初始化保持静音
  71   1      }
  72          
  73          //乐谱播放主函数
  74          void Music_Play(unsigned char code *song_data) {
  75   1          unsigned int i = 0; 
  76   1          
  77   1          while(song_data[i] != 0xFF) { 
  78   2              if(song_data[i] == 0) {
  79   3                  current_freq = 0;
  80   3                  TR0 = 0;      
  81   3                  BUZZER = 1;   
  82   3              } else {
  83   3                  current_freq = Note_Freq_Table[song_data[i]];
  84   3                  TH0 = current_freq >> 8;   
  85   3                  TL0 = current_freq & 0xFF; 
  86   3                  TR0 = 1;      
  87   3              }
  88   2              
  89   2              Delay_ms(song_data[i+1] * 250);
  90   2              
  91   2              TR0 = 0;      
  92   2              BUZZER = 1;   
  93   2              Delay_ms(15); //音符间断开
  94   2              
  95   2              i += 2;
  96   2          }
  97   1      }
  98          
  99          //方波产生器
 100          void Timer0_Routine() interrupt 1 {
 101   1          TH0 = current_freq >> 8;
 102   1          TL0 = current_freq & 0xFF;
 103   1          BUZZER = ~BUZZER; 
 104   1      }
 105          
 106          // 主程序入口
 107          void main() {
